      "modules": [
        "app.adapters.telegram_adapter",
        "app.adapters.line_adapter",
        "app.adapters.unified"
      ],
      "allowed_dependencies": []
    },
    {
      "name": "processing",
      "modules": [
        "app.processing.sanitizer",
        "app.processing.pii_masker",
        "app.processing.pipeline"
      ],
      "allowed_dependencies": []
    },
    {
      "name": "knowledge",
